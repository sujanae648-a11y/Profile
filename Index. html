        ];

        let cart = [];
        let isCartOpen = false;

        const formatRupiah = (number) => {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(number);
        };

        const showToast = (message) => {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = 'bg-gray-900 text-white px-5 py-4 rounded-2xl shadow-2xl text-sm font-medium flex items-center gap-3 transform translate-y-12 opacity-0 transition-all duration-400 ease-out pointer-events-auto border border-gray-700';
            toast.innerHTML = `<div class="bg-green-500/20 text-green-400 p-1 rounded-full flex-shrink-0"><i class="ph ph-check text-lg"></i></div><span>${message}</span>`;
            container.appendChild(toast);
            requestAnimationFrame(() => toast.classList.remove('translate-y-12', 'opacity-0'));
            setTimeout(() => {
                toast.classList.add('translate-y-12', 'opacity-0');
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        };

        const renderProducts = () => {
            const container = document.getElementById('product-container');
            container.innerHTML = '';
            products.forEach(product => {
                const badgeHTML = product.badge ? `<div class="absolute top-3 left-3 bg-brand-600 text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider shadow-md z-10">${product.badge}</div>` : '';
                const card = document.createElement('div');
                card.className = 'bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300 flex flex-col group';
                card.innerHTML = `
                    <div class="relative w-full pt-[100%] bg-gray-50 overflow-hidden">
                        ${badgeHTML}
                        <img src="${product.image}" alt="" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
                        <button onclick="addToCart(${product.id})" class="absolute bottom-3 right-3 bg-white/90 backdrop-blur text-gray-900 w-10 h-10 rounded-full flex justify-center items-center shadow-lg transform translate-y-12 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300 hover:bg-brand-600 hover:text-white">
                            <i class="ph ph-plus font-bold text-xl"></i>
                        </button>
                    </div>
                    <div class="p-5 flex flex-col flex-1">
                        <span class="text-[11px] font-bold text-gray-400 mb-2 uppercase tracking-widest">${product.category}</span>
                        <h3 class="text-sm sm:text-base font-semibold text-gray-900 leading-snug mb-3 flex-1 group-hover:text-brand-600 transition-colors">${product.name}</h3>
                        <div class="flex items-center justify-between mt-auto">
                            <span class="font-bold text-lg text-gray-900">${formatRupiah(product.price)}</span>
                        </div>
                        <button onclick="addToCart(${product.id})" class="mt-4 w-full bg-gray-50 hover:bg-brand-50 text-brand-600 font-semibold py-2.5 rounded-xl text-sm transition-colors flex justify-center items-center gap-2 lg:hidden">
                            <i class="ph ph-shopping-cart"></i> Beli
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });
        };

        const addToCart = (productId) => {
            const product = products.find(p => p.id === productId);
            const existingItem = cart.find(item => item.id === productId);
            if (existingItem) existingItem.quantity += 1;
            else cart.push({ ...product, quantity: 1 });
            updateCartUI();
            showToast(`<b>${product.name}</b> masuk keranjang!`);
        };

        const removeFromCart = (productId) => {
            cart = cart.filter(item => item.id !== productId);
            updateCartUI();
        };

        const updateQuantity = (productId, delta) => {
            const item = cart.find(item => item.id === productId);
            if (item) {
                item.quantity += delta;
                if (item.quantity <= 0) removeFromCart(productId);
                else updateCartUI();
            }
        };

        const updateCartUI = () => {
            const totalItems = cart.reduce((sum, item) => sum + item.quantity, 0);
            const badge = document.getElementById('cart-badge');
            
            if (totalItems > 0) {
                badge.textContent = totalItems;
                badge.classList.remove('opacity-0', 'scale-50');
                badge.classList.add('scale-100', 'scale-125');
                setTimeout(() => badge.classList.remove('scale-125'), 150);
            } else {
                badge.classList.add('opacity-0', 'scale-50');
                badge.classList.remove('scale-100');
            }

            const container = document.getElementById('cart-items');
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full text-gray-400 gap-4 mt-20">
                        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center">
                            <i class="ph ph-shopping-bag-open text-5xl text-gray-300"></i>
                        </div>
                        <p class="font-medium text-gray-500">Keranjang masih kosong.</p>
                        <button onclick="toggleCart()" class="mt-2 text-brand-600 font-semibold text-sm bg-brand-50 px-6 py-2.5 rounded-full hover:bg-brand-100 transition-colors">Belanja Dulu Yuk</button>
                    </div>
                `;
            } else {
                container.innerHTML = cart.map(item => `
                    <div class="bg-white p-4 rounded-2xl flex gap-4 shadow-sm border border-gray-100 relative">
                        <div class="w-20 h-20 bg-gray-100 rounded-xl overflow-hidden flex-shrink-0">
                            <img src="${item.image}" alt="" class="w-full h-full object-cover">
                        </div>
                        <div class="flex-1 flex flex-col justify-between">
                            <div class="pr-6">
                                <h4 class="text-sm font-semibold text-gray-900 leading-tight mb-1">${item.name}</h4>
                                <span class="font-bold text-sm text-brand-600">${formatRupiah(item.price)}</span>
                            </div>
                            <div class="flex justify-between items-center mt-2">
                                <div class="flex items-center bg-gray-50 border border-gray-200 rounded-lg overflow-hidden">
                                    <button onclick="updateQuantity(${item.id}, -1)" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-gray-900 font-medium">-</button>
                                    <span class="text-xs font-bold w-6 text-center text-gray-700">${item.quantity}</span>
                                    <button onclick="updateQuantity(${item.id}, 1)" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-gray-900 font-medium">+</button>
                                </div>
                            </div>
                        </div>
                        <button onclick="removeFromCart(${item.id})" class="absolute top-4 right-4 text-gray-300 hover:text-rose-500 bg-white rounded-full p-1 transition-colors">
                            <i class="ph ph-trash text-lg"></i>
                        </button>
                    </div>
                `).join('');
            }
            const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            document.getElementById('cart-total').textContent = formatRupiah(totalPrice);
        };

        const toggleCart = () => {
            const overlay = document.getElementById('cart-overlay');
            const sidebar = document.getElementById('cart-sidebar');
            const body = document.body;
            isCartOpen = !isCartOpen;
            if (isCartOpen) {
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
                sidebar.classList.remove('translate-x-full');
                body.style.overflow = 'hidden';
            } else {
                overlay.classList.add('opacity-0');
                sidebar.classList.add('translate-x-full');
                body.style.overflow = '';
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        };

        // --- FUNGSI CHECKOUT LINK KE WHATSAPP ---
        const checkoutToWhatsApp = () => {
            if (cart.length === 0) {
                showToast("Keranjang Anda masih kosong!");
                return;
            }

            // 1. Hitung Total
            const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
            
            // 2. Buat teks pesan (Formatnya rapih)
            let messageText = `Halo admin EgiShop,%0A%0ASaya ingin memesan produk berikut:%0A%0A`;
            
            // Loop semua barang di keranjang
            cart.forEach((item, index) => {
                messageText += `${index + 1}. *${item.name}* (x${item.quantity}) - ${formatRupiah(item.price * item.quantity)}%0A`;
            });

            messageText += `%0A*Total Belanja: ${formatRupiah(totalPrice)}*%0A%0A`;
            messageText += `Mohon info untuk total ongkos kirim dan metode pembayarannya. Terima kasih.`;

            // 3. Buat URL WhatsApp
            const waURL = `https://wa.me/${myWhatsAppNumber}?text=${messageText}`;

            // 4. Tutup keranjang & Buka link di tab baru
            toggleCart();
            window.open(waURL, '_blank');
            
            // Opsional: Kosongkan keranjang setelah menekan checkout
            cart = [];
            updateCartUI();
        };

        document.addEventListener('DOMContentLoaded', () => {
            renderProducts();
            updateCartUI();
        });
    </script>
